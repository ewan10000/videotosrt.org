{
  "name": "videotosrt-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "db:migrate:local": "wrangler d1 execute videotosrt-db --local --file=./migrations/0001_init.sql",
    "db:migrate:remote": "wrangler d1 execute videotosrt-db --remote --file=./migrations/0001_init.sql"
  },
  "dependencies": {
    "hono": "^4.7.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250501.0",
    "typescript": "^5.7.0",
    "wrangler": "^4.0.0"
  }
}
